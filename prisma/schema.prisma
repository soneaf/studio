// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin", "darwin-arm64"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Campaign {
  id          String     @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  clientId    String?
  cocktails   Cocktail[]
}

model Cocktail {
  id          String    @id @default(uuid())
  timestamp   DateTime  @default(now())
  recipeName  String
  sku         String
  glassware   String
  ice         String
  garnishes   String
  background  String
  countertop  String
  showBottle  Boolean
  imagePath   String?
  finalPrompt String
  mode        String?   @default("tequila")
  productName String?
  lighting    String?
  camera      String?
  angle       String?
  aspectRatio String?
  campaignId  String?
  campaign    Campaign? @relation(fields: [campaignId], references: [id])
}
